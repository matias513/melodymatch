generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Search {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  zcr        Float
  energy     Float
  density    Float
  length     Float

  topTitle   String?
  confidence Int?

  @@index([createdAt])
  @@index([topTitle])
  @@index([confidence])
}

model Song {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  title       String
  artist      String
  country     String
  region      String
  fingerprint String

  @@index([title])
  @@index([artist])
  @@index([region])
  @@unique([title, artist])
}
